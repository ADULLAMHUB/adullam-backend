// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MENTOR
}

model User {
  id           String         @id @default(uuid())
  firstName    String
  lastName     String
  phoneNumber  String
  password     String
  organization String?
  token        String?
  belief       String?
  email        String         @unique
  isOnline     Boolean
  role         Role
  notification Notification[]
  createdAt    DateTime       @default(now())
  lastActive   DateTime?
  updatedAt    DateTime?
}

model Notification {
  id      String @id @default(uuid())
  message String
  type    String
  to      Role
  userId  String
  user    User   @relation(fields: [userId], references: [id])

  @@index([to, userId])
}
